{
	"schemaVersion": 1,
	"id": "speedmine",
	"version": "${version}",
	"name": "Harvester",
	"description": "A client-side Fabric mod for accelerated mining with basic anti-cheat bypasses.",
	"authors": [
		"MadEthan6"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/speedmine/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.example.SpeedmineMod"
		],
		"client": [
			"com.example.client.SpeedmineModClient"
		]
	},
	"mixins": [
		"speedmine.mixins.json",
		{
			"config": "speedmine.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "*",
		"java": ">=25",
		"fabric-api": "*"
	}
}